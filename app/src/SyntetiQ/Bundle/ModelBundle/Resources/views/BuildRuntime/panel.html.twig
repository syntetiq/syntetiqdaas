<style>
    .sq-build-runtime-panel {
        padding: 16px;
        background: #fff;
        border: 1px solid #e5e8ef;
        border-radius: 6px;
    }

    .sq-build-runtime-panel__header {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        align-items: flex-start;
        flex-wrap: wrap;
        margin-bottom: 14px;
    }

    .sq-build-runtime-panel__title {
        margin: 0 0 6px;
        font-size: 18px;
        font-weight: 600;
        color: #1f2d3d;
    }

    .sq-build-runtime-panel__meta {
        color: #5f6b7a;
        font-size: 13px;
    }

    .sq-build-runtime-panel__status {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 12px;
        padding: 4px 10px;
        border-radius: 999px;
        text-transform: uppercase;
        font-weight: 600;
        letter-spacing: .04em;
    }

    .sq-build-runtime-panel__status--pending {
        background: #eef2ff;
        color: #4338ca;
    }

    .sq-build-runtime-panel__status--running {
        background: #ecfeff;
        color: #0f766e;
    }

    .sq-build-runtime-panel__status--finished {
        background: #ecfdf3;
        color: #166534;
    }

    .sq-build-runtime-panel__files {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 12px;
    }

    .sq-build-runtime-panel__file {
        border: 1px solid #e5e8ef;
        border-radius: 6px;
        padding: 12px;
        background: #fbfcfe;
    }

    .sq-build-runtime-panel__file-title {
        margin: 0 0 6px;
        font-size: 14px;
        font-weight: 600;
        color: #1f2d3d;
    }

    .sq-build-runtime-panel__file-description {
        font-size: 12px;
        color: #64748b;
        margin: 0 0 10px;
    }

    .sq-build-runtime-panel__file-actions {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        font-size: 12px;
    }

    .sq-build-runtime-panel__message,
    .sq-build-runtime-panel__empty {
        padding: 14px;
        border-radius: 6px;
        border: 1px solid #e5e8ef;
        background: #fff;
        color: #334155;
    }
</style>

{% set buildLogsStatus = buildLogs.status|default('pending') %}
{% set showTitle = showTitle is defined ? showTitle : true %}

<div class="sq-build-runtime-panel">
    <div class="sq-build-runtime-panel__header">
        <div>
            {% if showTitle %}
                <h3 class="sq-build-runtime-panel__title">Build Logs</h3>
            {% endif %}
            <div class="sq-build-runtime-panel__meta">
                Started:
                <strong>{{ buildLogs.startedAt ? buildLogs.startedAt|oro_format_datetime : 'N/A' }}</strong>
                |
                Finished:
                <strong>{{ buildLogs.finishedAt ? buildLogs.finishedAt|oro_format_datetime : 'N/A' }}</strong>
            </div>
        </div>
        <div>
            <span class="sq-build-runtime-panel__status sq-build-runtime-panel__status--{{ buildLogsStatus|e('html_attr') }}">
                {{ buildLogsStatus }}
            </span>
        </div>
    </div>

    {% if buildLogs.files is not empty %}
        <div class="sq-build-runtime-panel__files">
            {% for item in buildLogs.files %}
                <div class="sq-build-runtime-panel__file">
                    <h4 class="sq-build-runtime-panel__file-title">{{ item.label }}</h4>
                    {% if item.description %}
                        <p class="sq-build-runtime-panel__file-description">{{ item.description }}</p>
                    {% endif %}
                    <div class="sq-build-runtime-panel__file-actions">
                        <a href="{{ item.url }}" class="no-hash" target="_blank" rel="noopener noreferrer">View</a>
                        <a href="{{ item.downloadUrl }}" class="no-hash" download>Download</a>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% elseif buildLogsStatus == 'running' %}
        <div class="sq-build-runtime-panel__message">Build logs are being synced to shared storage while the build is running. Refresh the page to see newly available files.</div>
    {% else %}
        <div class="sq-build-runtime-panel__empty">No build runtime logs are available yet.</div>
    {% endif %}
</div>
